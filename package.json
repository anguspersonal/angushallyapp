{
  "name": "angushallyapp",
  "version": "4.0.0",
  "description": "Angus Hally's personal website — Next.js + Supabase",
  "private": true,
  "engines": {
    "node": "20.x",
    "npm": ">=10.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:turbopack": "next dev --turbopack",
    "prebuild": "node scripts/build-chat-knowledge.mjs && node scripts/build-chat-routes.mjs",
    "build": "next build",
    "build:chat": "node scripts/build-chat-knowledge.mjs && node scripts/build-chat-routes.mjs",
    "start": "next start",
    "lint": "next lint && node scripts/check-breakpoints.mjs --quiet",
    "check:breakpoints": "node scripts/check-breakpoints.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "fix-nextjs": "node scripts/fix-nextjs-build-errors.js",
    "fix-nextjs:clean": "node scripts/fix-nextjs-build-errors.js --clean-deps",
    "optimize-images": "node scripts/optimize-images.mjs",
    "clean:node": "bash scripts/clean-node.sh",
    "clean:next": "bash scripts/clean-next.sh",
    "clean:ports": "node scripts/clean-ports.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@mantine/charts": "^8.1.3",
    "@mantine/core": "^8.1.3",
    "@mantine/form": "^8.1.3",
    "@mantine/notifications": "^8.1.3",
    "@react-oauth/google": "^0.12.2",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.101.1",
    "@tabler/icons-react": "^3.34.0",
    "@types/react-google-recaptcha": "^2.1.9",
    "@vis.gl/react-google-maps": "^1.5.4",
    "autoprefixer": "^10.4.21",
    "axios": "^1.7.9",
    "critters": "^0.0.25",
    "dotenv": "^16.4.7",
    "framer-motion": "^12.23.0",
    "next": "^15.3.5",
    "next-pwa": "^5.6.0",
    "nodemailer": "^6.10.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-google-recaptcha": "^3.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.0.13",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.2.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.5",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "kill-port": "^2.0.1",
    "vitest": "^1.2.1"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "cross-spawn": "^7.0.6",
    "got": "^11.8.5",
    "http-cache-semantics": "^4.1.1",
    "semver": "^7.5.2",
    "semver-regex": "^4.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angushally/angushallyapp.git"
  },
  "keywords": [
    "nextjs",
    "react",
    "supabase",
    "postgresql"
  ],
  "license": "MIT",
  "author": "angushally",
  "bugs": {
    "url": "https://github.com/angushally/angushallyapp/issues"
  },
  "homepage": "https://github.com/angushally/angushallyapp#readme"
}
