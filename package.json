{
  "name": "angushallyapp",
  "version": "4.0.0",
  "description": "Angus Hally's personal application - Next.js frontend with Supabase backend",
  "private": true,
  "workspaces": [
    "web"
  ],
  "engines": {
    "node": "20.x",
    "npm": ">=10.x"
  },
  "scripts": {
    "build": "cd web && npm run build",
    "dev": "cd web && npm run dev",
    "start": "cd web && npm run start",
    "kill-ports": "npx kill-port 3000",
    "compress-images": "node scripts/compress-images.mjs",
    "compress-big": "node scripts/compress-big-only.mjs",
    "clean:node": "bash scripts/clean-node.sh",
    "clean:next": "bash scripts/clean-next.sh",
    "clean:public": "node scripts/clean-public.js",
    "clean:ports": "node scripts/clean-ports.js"
  },
  "type": "commonjs",
  "cacheDirectories": [
    "node_modules",
    "web/node_modules"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "apify-client": "^2.12.6",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "fuse.js": "^7.0.0",
    "nodemailer": "^6.10.0",
    "open-graph-scraper": "^6.10.0",
    "openai": "^4.100.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "concurrently": "^9.1.2",
    "eslint-config-next": "^15.3.5",
    "kill-port": "^2.0.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angushally/angushallyapp.git"
  },
  "keywords": [
    "nextjs",
    "react",
    "supabase",
    "postgresql"
  ],
  "license": "MIT",
  "author": "angushally",
  "bugs": {
    "url": "https://github.com/angushally/angushallyapp/issues"
  },
  "homepage": "https://github.com/angushally/angushallyapp#readme",
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "cross-spawn": "^7.0.6",
    "got": "^11.8.5",
    "http-cache-semantics": "^4.1.1",
    "semver": "^7.5.2",
    "semver-regex": "^4.0.2"
  },
  "optionalDependencies": {
    "imagemin": "^9.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "pngquant-bin": "^7.0.0"
  }
}
