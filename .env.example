# ============================================================================
#  .env.example — template for contributors
# ============================================================================
#
# Copy this file to .env.local and fill in real values.
# Every var below is one the app actually reads (grepped from src/).
# Do NOT commit .env.local — it is gitignored.
#
# Production/preview env vars live in the Vercel project dashboard, not here.
# ----------------------------------------------------------------------------

# ---------- Supabase (database + auth) --------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# Alternative legacy name (fallback):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — bypasses RLS, never expose to the client
SUPABASE_SECRET_KEY=sb_secret_...
# Alternative legacy name (fallback):
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------- reCAPTCHA v3 (contact form) -------------------------------------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lc...
RECAPTCHA_SECRET_KEY=6Lc...

# ---------- Email (contact form notifications) ------------------------------
# Two auth modes — use one. Both need SMTP_HOST/PORT/USER and RECIPIENT_EMAIL.
#
# Mode 1: Password auth (simplest)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
RECIPIENT_EMAIL=you@example.com
#
# Mode 2: Google OAuth2 (leave SMTP_PASS blank and set these instead)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=

# ---------- Google Maps (eat-safe-uk map project) --------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=<map-id>

# ---------- OpenAI (text analysis + Instagram intelligence) ----------------
OPENAI_API_KEY=sk-...
# Optional — has a hardcoded default
# OPENAI_INSTAGRAM_ASSISTANT_ID=asst_...

# ---------- Apify (Instagram intelligence) ----------------------------------
APIFY_API_TOKEN=apify_api_...
APIFY_INSTAGRAM_ACTOR_ID=<actor-id>

# ---------- Raindrop.io (bookmarks OAuth) -----------------------------------
RAINDROP_CLIENT_ID=<client-id>
RAINDROP_CLIENT_SECRET=<client-secret>
RAINDROP_REDIRECT_URI=http://localhost:3000/api/raindrop/oauth/callback

# ---------- Strava (activity sync via daily Vercel Cron) --------------------
STRAVA_CLIENT_ID=<client-id>
STRAVA_CLIENT_SECRET=<client-secret>

# ---------- Cron protection -------------------------------------------------
# Any random opaque string. Vercel Cron sends `Authorization: Bearer <value>`
# automatically when this is set as an env var on the project.
# Generate one with: openssl rand -hex 32
CRON_SECRET=<random-secret>

# ---------- Footer build info (optional) ------------------------------------
# NEXT_PUBLIC_BUILD_NUMBER=dev
