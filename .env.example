# reCAPTCHA (server-side secret + client-side site key)
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# OpenAI
OPENAI_API_KEY=

# Email (nodemailer — supports OAuth2 or password auth)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
RECIPIENT_EMAIL=

# Google OAuth for email sending (optional — use instead of SMTP_PASS)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Supabase (Next Route Handlers — content, habit, strava)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Database (optional — local Knex / server/ migrations)
DATABASE_URL=

# Vercel (optional — useful for preview URLs)
NEXT_PUBLIC_SITE_URL=
