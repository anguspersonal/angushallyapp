# ============================================================================
#  .env.example — template for contributors
# ============================================================================
#
# Copy this file to .env.local and fill in real values.
# Every var below is one the app actually reads (grepped from src/).
# Do NOT commit .env.local — it is gitignored.
#
# Production/preview env vars live in the Vercel project dashboard, not here.
# ----------------------------------------------------------------------------

# ---------- Supabase (database + auth) --------------------------------------
# REQUIRED for `npm run build` to complete — without these, prerendering of
# routes that touch Supabase (e.g. /contact) fails with:
#   "@supabase/ssr: Your project's URL and API key are required to create a
#    Supabase client!"
# Grab values from the Supabase dashboard:
#   https://supabase.com/dashboard/project/<your-project-ref>/settings/api
# See docs/guides/local-build.md and issue #61 for context.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Code reads NEXT_PUBLIC_SUPABASE_ANON_KEY first, with PUBLISHABLE_DEFAULT_KEY as fallback.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Alternative name (fallback):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Server-only — bypasses RLS, never expose to the client
# Code reads SUPABASE_SECRET_KEY first, with SERVICE_ROLE_KEY as fallback.
SUPABASE_SECRET_KEY=sb_secret_...
# Alternative name (fallback):
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_URL is also read as a fallback for NEXT_PUBLIC_SUPABASE_URL on the
# admin client (src/lib/supabase/admin.ts):
# SUPABASE_URL=https://<project-ref>.supabase.co

# ---------- reCAPTCHA v3 (contact form) -------------------------------------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lc...
RECAPTCHA_SECRET_KEY=6Lc...

# ---------- Email (contact form notifications) ------------------------------
# Two auth modes — use one. Both need SMTP_HOST/PORT/USER and RECIPIENT_EMAIL.
#
# Mode 1: Password auth (simplest)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
RECIPIENT_EMAIL=you@example.com
#
# Mode 2: Google OAuth2 (leave SMTP_PASS blank and set these instead)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=

# ---------- Google Maps (eat-safe-uk map project) --------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=<map-id>

# ---------- OpenAI (text analysis + Instagram intelligence) ----------------
OPENAI_API_KEY=sk-...
# Optional — has a hardcoded default
# OPENAI_INSTAGRAM_ASSISTANT_ID=asst_...

# ---------- Apify (Instagram intelligence) ----------------------------------
APIFY_API_TOKEN=apify_api_...
APIFY_INSTAGRAM_ACTOR_ID=<actor-id>

# ---------- Raindrop.io (bookmarks OAuth) -----------------------------------
RAINDROP_CLIENT_ID=<client-id>
RAINDROP_CLIENT_SECRET=<client-secret>
RAINDROP_REDIRECT_URI=http://localhost:3000/api/raindrop/oauth/callback

# ---------- Strava (activity sync via daily Vercel Cron) --------------------
STRAVA_CLIENT_ID=<client-id>
STRAVA_CLIENT_SECRET=<client-secret>

# ---------- Cron protection -------------------------------------------------
# Any random opaque string. Vercel Cron sends `Authorization: Bearer <value>`
# automatically when this is set as an env var on the project.
# Generate one with: openssl rand -hex 32
CRON_SECRET=<random-secret>

# ---------- PostHog analytics (consent-gated) -------------------------------
# angushallyapp's OWN PostHog project — NOT the HeyLina one. See issue #141 and
# docs/guides/analytics.md.
#
# OWNER ACTION: create a dedicated PostHog project for angushallyapp and paste
# its Project API key here (and on the Vercel project for prod/preview). The
# analytics layer NO-OPs when this key is ABSENT — the site ships keyless today
# and lights up the moment the key is set. PostHog is ONLY initialised after the
# visitor grants the Analytics consent category; revoking it stops capture.
#
# Optional — host defaults to https://eu.i.posthog.com when unset (use
# https://us.i.posthog.com for the US cloud, or your reverse-proxy host).
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ---------- Footer build info (optional) ------------------------------------
# NEXT_PUBLIC_BUILD_NUMBER=dev

# ---------- Chat (v1) ------------------------------------------------------
# See docs/chatbotv1/README.md for the full picture.

# LLM provider — Anthropic, model claude-haiku-4-5-20251001. Get a key from
# https://console.anthropic.com. Server-only.
ANTHROPIC_API_KEY=sk-ant-...

# Spend cap in USD per UTC day. When exceeded, the chat panel switches to a
# static "resting" state and serves a fallback FAQ. Set a conservative value
# while iterating — 5 USD/day is plenty for the traffic this site sees.
CHAT_DAILY_SPEND_CAP_USD=5

# Pricing inputs for the spend-cap aggregate query. Units: USD per 1,000,000
# tokens, decimal. Update these when Anthropic changes Haiku 4.5 pricing.
# Current published pricing at the time of writing:
#   input  $1.00 / 1M tokens
#   output $5.00 / 1M tokens
CHAT_INPUT_PRICE_USD_PER_MILLION_TOKENS=1.00
CHAT_OUTPUT_PRICE_USD_PER_MILLION_TOKENS=5.00

# Server-only pepper for IP hashing. Salts the SHA-256 so a stored hash
# cannot be reversed from a known IP without the pepper. Rotating it
# invalidates correlation across the rotation point but leaks no historical
# IP. Generate with: openssl rand -hex 32
CHAT_IP_HASH_PEPPER=<random-hex>

